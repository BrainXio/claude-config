{
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "ssh",
      "gpg",
      "gpg2",
      "gh",
      "docker",
      "docker-compose",
      "podman",
      "sudo",
      "su",
      "pkexec",
      "doas"
    ],
    "filesystem": {
      "allowRead": [
        ".",
        "~/.claude",
        "/tmp"
      ],
      "denyRead": [
        "~/.ssh/vault/**",
        "~/.aws",
        "~/.netrc",
        "~/.kube",
        "~/.docker",
        "~/.npm",
        "~/.yarn",
        "~/.cache/pip",
        "~/.config/gh/hosts.yml",
        "**/.env*",
        "**/secrets/**",
        "**/credentials/**",
        "**/private/**",
        "**/*.pem",
        "**/*.key",
        "**/*.crt",
        "**/*.p12",
        "**/*.pfx"
      ],
      "allowWrite": [
        ".",
        "~/.claude",
        "/tmp"
      ],
      "denyWrite": [
        "~/.ssh/vault/**",
        "/etc",
        "/usr",
        "/bin",
        "/sbin",
        "/root"
      ]
    }
  }
}
