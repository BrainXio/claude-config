{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-bootstrap",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "claude-session-start",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash ${workspaceFolder}/claude-cli/bin/check-model-vision",
            "timeout": 60
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-pre-compact",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-session-end",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "claude-standards-guard",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
