#!/usr/bin/env bash
# Pre-commit hook for claude-config
# Runs markdown/yaml linting and attribution guard.
set -euo pipefail

ATTRIBUTION_PATTERNS=(
  "[Cc]o-authored[- ]by"
  "[Gg]enerated[- ]by[- ]AI"
  "[Aa]I[- ]generated"
  "[Ww]ritten[- ]by[- ](Claude|ChatGPT|Copilot|Gemini)"
  "[Cc]reated[- ]with[- ](Claude|ChatGPT|Copilot|Gemini)"
  "GitHub[- ]Copilot"
)

staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -z "$staged_files" ]; then
  exit 0
fi

echo "Running pre-commit checks for claude-config..."

# --- Markdown checks ---
md_files=$(echo "$staged_files" | grep -E '\.md$' || true)
if [ -n "$md_files" ]; then
  if command -v mdformat &>/dev/null; then
    echo "Checking markdown formatting (mdformat)..."
    echo "$md_files" | xargs -r mdformat --check || {
      echo "Run 'mdformat' to fix markdown formatting."
      exit 1
    }
  fi
fi

# --- YAML checks ---
yaml_files=$(echo "$staged_files" | grep -E '\.ya?ml$' || true)
if [ -n "$yaml_files" ]; then
  if command -v yamllint &>/dev/null; then
    echo "Running yamllint..."
    echo "$yaml_files" | xargs -r yamllint -c .yamllint || {
      echo "Fix YAML linting errors before committing."
      exit 1
    }
  fi
fi

# --- Attribution guard ---
violations=0
for file in README.md CONTRIBUTING.md SECURITY.md; do
  if echo "$staged_files" | grep -qx "$file"; then
    content=$(git show ":$file" 2>/dev/null || true)
    if [ -z "$content" ]; then
      continue
    fi
    for pattern in "${ATTRIBUTION_PATTERNS[@]}"; do
      matches=$(echo "$content" | grep -inE "$pattern" 2>/dev/null || true)
      if [ -n "$matches" ]; then
        echo "ERROR: forbidden attribution pattern in $file:" >&2
        echo "$matches" | head -5 >&2
        violations=$((violations + 1))
      fi
    done
  fi
done

if [ "$violations" -gt 0 ]; then
  echo "Attribution guard: $violations violation(s) found. Remove AI attribution before committing." >&2
  exit 1
fi

echo "Pre-commit checks passed."
exit 0
