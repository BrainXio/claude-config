{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",

    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_UPDATES": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",

    "CLAUDE_CODE_SKIP_PROMPT_HISTORY": "0",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",

    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "0",
    "CLAUDE_CODE_DISABLE_MOUSE": "0",

    "ANTHROPIC_LOG": "warn",

    "CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK": "0",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "0",
    "DISABLE_PROMPT_CACHING_SONNET": "0"
  },

  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-bootstrap",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "claude-session-start",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash ${workspaceFolder}/claude-cli/bin/check-model-vision",
            "timeout": 60
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-pre-compact",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-session-end",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "claude-standards-guard",
            "timeout": 10
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Read(~/.claude)",
      "Write(~/.claude)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.crt)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/vault/**)",
      "Read(**/.gnupg/private-keys-v1.d/**)",
      "Read(~/Library/Keychains/**)",
      "Read(**/private/**)",
      "Write(~/.ssh/vault/**)",
      "Run(docker)",
      "Run(docker-compose)",
      "Run(podman)",
      "Run(sudo)",
      "Run(su)",
      "Run(pkexec)",
      "Run(doas)"
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "uvx --from git+https://github.com/BrainXio/claude-cli.git claude-statusline"
  }
}
