{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/BrainXio/claude-cli@v0.1.0 claude-bootstrap",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/BrainXio/claude-cli@v0.1.0 claude-session-start",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/BrainXio/claude-cli@v0.1.0 claude-check-model-vision",
            "timeout": 60
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/BrainXio/claude-cli@v0.1.0 claude-pre-compact",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/BrainXio/claude-cli@v0.1.0 claude-session-end",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/BrainXio/claude-cli@v0.1.0 claude-standards-guard",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from git+https://github.com/BrainXio/claude-cli@v0.1.0 claude-post-tool-use",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
