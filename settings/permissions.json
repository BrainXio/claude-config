{
  "permissions": {
    "allow": [
      "Read(~/.claude)",
      "Write(~/.claude)",
      "Read(./.claude)",
      "Read(~/.config/claude)",
      "Bash(uv run claude-bus *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.crt)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/vault/**)",
      "Read(**/.gnupg/private-keys-v1.d/**)",
      "Read(~/Library/Keychains/**)",
      "Read(**/private/**)",
      "Write(~/.ssh/vault/**)",
      "Bash(docker: *)",
      "Bash(docker-compose: *)",
      "Bash(podman: *)",
      "Bash(sudo: *)",
      "Bash(su: *)",
      "Bash(pkexec: *)",
      "Bash(doas: *)"
    ]
  }
}
